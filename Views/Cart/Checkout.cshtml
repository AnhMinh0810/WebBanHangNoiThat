@model IEnumerable<furniture_store.Models.CartItem>

@{
    ViewData["Title"] = "Thanh Toán";
    decimal totalSum = Model.Sum(i => i.Total);
}

<div class="container mt-5 mb-5" style="max-width: 1100px;">
    <!-- Validation Summary -->
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger font-sans" role="alert" style="border-radius: var(--radius-sm); border-left: 4px solid var(--color-error); font-size: 0.9rem;">
            <div asp-validation-summary="All" class="text-danger"></div>
        </div>
    }

    <div class="row g-4">
        <!-- Order Form (Left Column) -->
        <div class="col-lg-7">
            <div class="luxe-card" style="padding: 32px; border-radius: var(--radius-lg);">
                <h2 class="font-serif mb-1" style="font-size: 1.8rem; font-weight: 600; color: var(--color-on-surface);">Thông Tin Đặt Hàng</h2>
                <p class="text-muted mb-4" style="font-size: 0.85rem;">Vui lòng điền đầy đủ thông tin để hoàn tất đơn hàng</p>

                <form asp-controller="Cart" asp-action="Checkout" method="post">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label-luxe" for="customerName">Họ và tên *</label>
                            <input type="text" id="customerName" name="customerName" class="form-control-luxe" required value="@ViewBag.CustomerName" placeholder="Nhập họ và tên..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label-luxe" for="customerPhone">Số điện thoại *</label>
                            <input type="text" id="customerPhone" name="customerPhone" class="form-control-luxe" required placeholder="0909 123 456" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <label class="form-label-luxe" for="customerEmail">Email</label>
                        <input type="email" id="customerEmail" name="customerEmail" class="form-control-luxe" value="@ViewBag.CustomerEmail" placeholder="admin@furniture.com" />
                    </div>

                    <div class="mt-3">
                        <label class="form-label-luxe" for="address">Địa chỉ giao hàng *</label>
                        <input type="text" id="address" name="address" class="form-control-luxe" required placeholder="Số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố" />
                    </div>

                    <div class="mt-3">
                        <label class="form-label-luxe" for="note">Ghi chú (tuỳ chọn)</label>
                        <textarea id="note" name="note" class="form-control-luxe" rows="3" placeholder="Ghi chú về đơn hàng, ví dụ: giao vào buổi chiều..."></textarea>
                    </div>

                    <!-- Payment Methods -->
                    <div class="mt-4">
                        <label class="form-label-luxe mb-3" style="font-weight: 700; font-size: 0.85rem; letter-spacing: 0.05em; text-transform: uppercase;">Phương thức thanh toán</label>
                        
                        <div class="d-flex flex-column gap-3">
                            <!-- COD Option -->
                            <label class="payment-method-card" style="display: flex; align-items: flex-start; gap: 16px; border: 1px solid var(--color-outline-variant); padding: 16px; border-radius: var(--radius-md); cursor: pointer; transition: all 0.2s ease;">
                                <input type="radio" name="paymentMethod" value="cod" checked style="margin-top: 4px; accent-color: var(--color-primary);" />
                                <div>
                                    <span style="font-weight: 600; display: block; color: var(--color-on-surface); font-size: 0.95rem;">💵 Tiền mặt (COD)</span>
                                    <span class="text-muted" style="font-size: 0.8rem;">Thanh toán khi nhận hàng</span>
                                </div>
                            </label>

                            <!-- Bank Transfer Option -->
                            <label class="payment-method-card" style="display: flex; align-items: flex-start; gap: 16px; border: 1px solid var(--color-outline-variant); padding: 16px; border-radius: var(--radius-md); cursor: pointer; transition: all 0.2s ease;">
                                <input type="radio" name="paymentMethod" value="bank" style="margin-top: 4px; accent-color: var(--color-primary);" />
                                <div>
                                    <span style="font-weight: 600; display: block; color: var(--color-on-surface); font-size: 0.95rem;">🏦 Chuyển khoản</span>
                                    <span class="text-muted" style="font-size: 0.8rem;">Chuyển khoản ngân hàng</span>
                                </div>
                            </label>

                            <!-- MoMo Option -->
                            <label class="payment-method-card" style="display: flex; align-items: flex-start; gap: 16px; border: 1px solid var(--color-outline-variant); padding: 16px; border-radius: var(--radius-md); cursor: pointer; transition: all 0.2s ease;">
                                <input type="radio" name="paymentMethod" value="momo" style="margin-top: 4px; accent-color: var(--color-primary);" />
                                <div>
                                    <span style="font-weight: 600; display: block; color: var(--color-on-surface); font-size: 0.95rem;">📱 Ví MoMo</span>
                                    <span class="text-muted" style="font-size: 0.8rem;">Thanh toán qua MoMo</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Submit Button -->
                    <div class="mt-4 pt-2">
                        <button type="submit" class="btn-luxe btn-luxe-primary w-100 py-3 d-flex align-items-center justify-content-center gap-2" style="font-size: 0.95rem; font-weight: 700; background-color: var(--color-primary-container);">
                            ✅ Đặt Hàng Ngay
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Order Summary (Right Column) -->
        <div class="col-lg-5">
            <div class="luxe-card" style="padding: 28px; border-radius: var(--radius-lg); position: sticky; top: 100px;">
                <h3 class="font-serif mb-4" style="font-size: 1.4rem; font-weight: 600; color: var(--color-on-surface); border-bottom: 1px solid var(--color-surface-container); padding-bottom: 16px;">
                    📋 Tóm Tắt Đơn Hàng
                </h3>

                <!-- Product List -->
                <div class="d-flex flex-column gap-3 mb-4" style="max-height: 350px; overflow-y: auto; padding-right: 4px;">
                    @foreach (var item in Model)
                    {
                        <div class="d-flex align-items-center justify-content-between gap-3">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@item.ImageUrl" alt="@item.Name" style="width: 50px; height: 50px; object-fit: cover; border-radius: var(--radius-sm); border: 1px solid var(--color-outline-variant);" onerror="this.onerror=null; this.src='/images/hero_sofa.png';" />
                                <div>
                                    <h4 style="font-size: 0.9rem; font-weight: 600; margin: 0; color: var(--color-on-surface);">@item.Name</h4>
                                    <span class="text-muted" style="font-size: 0.8rem;">SL: @item.Quantity</span>
                                </div>
                            </div>
                            <span class="text-gold font-weight-bold" style="font-size: 0.95rem;">@item.Total.ToString("N0") ₫</span>
                        </div>
                    }
                </div>

                <!-- Calculation Rows -->
                <div style="border-top: 1px solid var(--color-surface-container); padding-top: 16px; display: flex; flex-direction: column; gap: 10px;">
                    <div class="d-flex justify-content-between" style="font-size: 0.9rem;">
                        <span class="text-muted">Tạm tính</span>
                        <span style="font-weight: 600; color: var(--color-on-surface);">@totalSum.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between" style="font-size: 0.9rem;">
                        <span class="text-muted">Phí vận chuyển</span>
                        <span style="font-weight: 600; color: #198754;">Miễn phí</span>
                    </div>
                    <div class="d-flex justify-content-between pt-2" style="border-top: 1px dotted var(--color-outline-variant);">
                        <span style="font-weight: 700; color: var(--color-on-surface);">Tổng cộng</span>
                        <span class="text-gold font-weight-bold" style="font-size: 1.3rem;">@totalSum.ToString("N0") ₫</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .payment-method-card:has(input:checked) {
        border-color: var(--color-primary) !important;
        background-color: var(--color-surface-low) !important;
        box-shadow: 0 4px 12px rgba(184, 134, 11, 0.05);
    }
</style>
