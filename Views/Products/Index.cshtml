@model IEnumerable<furniture_store.Models.Product>

@{
    ViewData["Title"] = "Bộ Sưu Tập Sản Phẩm";
    var categories = ViewData["Categories"] as List<furniture_store.Models.Category> ?? new List<furniture_store.Models.Category>();
    var currentCategory = ViewData["CurrentCategory"] as string;
    var activeCategoryName = categories.FirstOrDefault(c => c.Slug == currentCategory)?.Name ?? "Tất Cả Sản Phẩm";
}

<div class="container mt-5 mb-5">
    <div class="page-header">
        <div>
            <h1 class="page-title">Cửa Hàng</h1>
            <p class="page-subtitle">@activeCategoryName (@ViewData["TotalItems"] sản phẩm)</p>
        </div>
        <div>
            @if (User.Identity.IsAuthenticated)
            {
                <a asp-action="Create" class="btn-luxe btn-luxe-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 4px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Thêm Mới
                </a>
            }
        </div>
    </div>

    <div class="catalog-wrapper">
        <aside class="catalog-sidebar">
            <h3 class="sidebar-title">Không Gian</h3>
            <ul class="sidebar-menu">
                <li>
                    <a href="/Products" class="@(string.IsNullOrEmpty(currentCategory) ? "active" : "")">Tất Cả Sản Phẩm</a>
                </li>
                @foreach (var cat in categories)
                {
                    <li>
                        <a href="/Products?category=@cat.Slug" class="@(currentCategory == cat.Slug ? "active" : "")">@cat.Name</a>
                    </li>
                }
            </ul>
        </aside>

        <div class="catalog-products">
            @if (!Model.Any())
            {
                <div class="text-center py-5 luxe-card">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted mb-3"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                    <h3 class="font-serif">Không tìm thấy sản phẩm</h3>
                    <p class="text-muted">Không có sản phẩm nào thuộc danh mục này hiện tại.</p>
                    <a href="/Products" class="btn-luxe btn-luxe-outline mt-3">Quay lại cửa hàng</a>
                </div>
            }
            else
            {
                <div class="products-grid">
                    @foreach (var item in Model)
                    {
                        <div class="product-card">
                            <div class="product-img-wrapper">
                                @if (item.Featured == true)
                                {
                                    <span class="product-badge">Nổi bật</span>
                                }
                                <img src="@item.ImageUrl" alt="@item.Name" class="product-img" onerror="this.onerror=null; this.src='/images/hero_sofa.png';" />
                            </div>
                            <div class="product-info">
                                <span class="product-category">@(item.Category != null ? item.Category.Name : "Nội Thất")</span>
                                <h3 class="product-title">
                                    <a asp-action="Details" asp-route-id="@item.Id">@item.Name</a>
                                </h3>
                                <div class="product-price">@item.Price.ToString("N0") ₫</div>
                                
                                <div class="product-actions" style="margin-top: auto; border-top: 1px solid var(--color-surface-container); padding-top: 16px;">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn-luxe btn-luxe-outline text-center py-2" style="font-size: 0.75rem; padding: 8px 12px;">Xem Chi Tiết</a>
                                    <form asp-controller="Cart" asp-action="Add" method="post" style="display: inline;">
                                        <input type="hidden" name="productId" value="@item.Id" />
                                        <button type="submit" class="btn-add-cart" title="Thêm vào giỏ">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                                        </button>
                                    </form>
                                </div>
                                

                            </div>
                        </div>
                    }
                </div>

                int totalPages = (ViewData["TotalPages"] as int?) ?? 1;
                int currentPage = (ViewData["CurrentPage"] as int?) ?? 1;
                if (totalPages > 1)
                {
                    <div class="luxe-pagination d-flex justify-content-center gap-2 mt-5">
                        @if (currentPage > 1)
                        {
                            <a href="@Url.Action("Index", new { category = currentCategory, page = currentPage - 1 })" class="btn-pagination">
                                &larr; Trước
                            </a>
                        }

                        @for (int i = 1; i <= totalPages; i++)
                        {
                            <a href="@Url.Action("Index", new { category = currentCategory, page = i })" class="btn-pagination @(i == currentPage ? "active" : "")">
                                @i
                            </a>
                        }

                        @if (currentPage < totalPages)
                        {
                            <a href="@Url.Action("Index", new { category = currentCategory, page = currentPage + 1 })" class="btn-pagination">
                                Sau &rarr;
                            </a>
                        }
                    </div>
                }
            }
        </div>
    </div>
</div>