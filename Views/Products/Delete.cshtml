@model furniture_store.Models.Product

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="container mt-5 mb-5" style="max-width: 640px;">
    <div class="page-header" style="border: none; margin-bottom: 24px; padding-bottom: 0;">
        <a asp-action="Index" class="text-muted" style="font-size: 0.85rem; display: flex; align-items: center; gap: 6px;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12,19 5,12 12,5"/></svg>
            Quay lại danh sách sản phẩm
        </a>
    </div>

    <div class="luxe-card" style="border-color: var(--color-error);">
        <h2 class="font-serif text-danger-luxe mb-3" style="font-size: 1.8rem;">Xác Nhận Xóa Sản Phẩm</h2>
        <p class="text-muted mb-4">Bạn có chắc chắn muốn xóa vĩnh viễn sản phẩm dưới đây? Hành động này không thể hoàn tác.</p>
        
        <div style="background-color: var(--color-surface-low); padding: 20px; border-radius: var(--radius-md); margin-bottom: 30px; display: flex; gap: 20px; align-items: center; border: 1px solid var(--color-surface-container);">
            <img src="@Model.ImageUrl" alt="@Model.Name" style="width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-sm); border: 1px solid var(--color-outline-variant);" onerror="this.onerror=null; this.src='/images/hero_sofa.png';" />
            <div>
                <span style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-outline);">
                    @(Model.Category != null ? Model.Category.Name : "Nội Thất")
                </span>
                <h4 class="font-serif m-0" style="font-size: 1.2rem;">@Model.Name</h4>
                <div class="text-gold font-weight-bold" style="margin-top: 4px;">@Model.Price.ToString("N0") ₫</div>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-3">
                <button type="submit" class="btn-luxe" style="background-color: var(--color-error); border: 1px solid var(--color-error); color: white;">
                    Xóa Vĩnh Viễn
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn-luxe btn-luxe-outline">
                    Hủy & Quay Lại
                </a>
            </div>
        </form>
    </div>
</div>
